{
  "info": {
    "name": "Marketing CRM API",
    "description": "Complete API collection for the Marketing CRM Laravel application. Set the `base_url` and `token` collection variables before use.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "marketing-crm-api-v1"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT Bearer token — set this after a successful login."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — registration, login, token refresh, logout, and current user.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"Password@123\",\n  \"password_confirmation\": \"Password@123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@marketingcrm.com\",\n  \"password\": \"password\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/refresh", "host": ["{{base_url}}"], "path": ["api","v1","auth","refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/logout", "host": ["{{base_url}}"], "path": ["api","v1","auth","logout"] }
          }
        },
        {
          "name": "Me (Current User)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/auth/me", "host": ["{{base_url}}"], "path": ["api","v1","auth","me"] }
          }
        }
      ]
    },
    {
      "name": "Campaigns",
      "description": "Campaign management — CRUD, stats, and send operations.",
      "item": [
        {
          "name": "List Campaigns",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/campaigns?page=1&per_page=15&status=active&type=email",
              "host": ["{{base_url}}"],
              "path": ["api","v1","campaigns"],
              "query": [
                { "key": "page",     "value": "1" },
                { "key": "per_page", "value": "15" },
                { "key": "status",   "value": "active",  "description": "Filter by status: draft|scheduled|active|paused|completed|cancelled" },
                { "key": "type",     "value": "email",   "description": "Filter by type: email|sms|push_notification|social_media" },
                { "key": "search",   "value": "",        "description": "Search by name or subject", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/campaigns", "host": ["{{base_url}}"], "path": ["api","v1","campaigns"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Black Friday 2024\",\n  \"type\": \"email\",\n  \"segment_id\": 1,\n  \"subject\": \"Our biggest sale of the year is here!\",\n  \"content\": \"<p>Hello {{first_name}}, shop now and save up to 70%.</p>\",\n  \"budget\": 5000,\n  \"scheduled_at\": \"2024-11-29T09:00:00Z\",\n  \"frequency\": \"one_time\",\n  \"ab_test_enabled\": false\n}"
            }
          }
        },
        {
          "name": "Show Campaign",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/campaigns/1", "host": ["{{base_url}}"], "path": ["api","v1","campaigns","1"] }
          }
        },
        {
          "name": "Update Campaign",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/campaigns/1", "host": ["{{base_url}}"], "path": ["api","v1","campaigns","1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Black Friday 2024 — Updated\",\n  \"status\": \"scheduled\",\n  \"budget\": 7500\n}"
            }
          }
        },
        {
          "name": "Delete Campaign",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/campaigns/1", "host": ["{{base_url}}"], "path": ["api","v1","campaigns","1"] }
          }
        },
        {
          "name": "Campaign Stats",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/campaigns/1/stats", "host": ["{{base_url}}"], "path": ["api","v1","campaigns","1","stats"] }
          }
        },
        {
          "name": "Send Campaign",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Accept",        "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/campaigns/1/send", "host": ["{{base_url}}"], "path": ["api","v1","campaigns","1","send"] }
          }
        }
      ]
